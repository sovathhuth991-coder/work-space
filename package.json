{
  "name": "workspace-hub",
  "version": "1.0.0",
  "private": true,
  "description": "Workspace Hub — personal productivity PWA. No build step; this package.json exists only to run stylelint locally before deploying.",
  "scripts": {
    "lint:css": "stylelint \"**/*.css\"",
    "build:tinybase": "node scripts/build-tinybase-iife.js",
    "sync:dev": "partykit dev --port 1999"
  },
  "devDependencies": {
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "partykit": "^0.0.115",
    "partysocket": "^1.3.0",
    "tinybase": "^9.2.0"
  }
}
